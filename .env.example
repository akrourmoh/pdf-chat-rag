# Copy this file to ".env" and fill in your real values.
# The real .env file is gitignored and must NEVER be committed.

# ── Required ────────────────────────────────────────────────────────────────
# Google Gemini API key:  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key

# Secret used to sign login (JWT) tokens. Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-long-random-secret

# ── Environment ─────────────────────────────────────────────────────────────
# "development" (lenient) or "production" (enforces secure settings at startup).
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────────────
# Defaults to local SQLite if omitted. In production use PostgreSQL, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///users.db

# ── Optional overrides (sensible defaults exist in config.py) ────────────────
# EMBED_MODEL=gemini-embedding-001
# LLM_MODEL=gemini-2.5-flash
# LLM_FALLBACK_MODEL=gemini-2.0-flash
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# TOP_K=4

# ── Vector database (Qdrant) ─────────────────────────────────────────────────
# Leave QDRANT_URL empty to use a local on-disk database (good for dev).
# For production, point to a hosted Qdrant (e.g. Qdrant Cloud):
# QDRANT_URL=https://your-instance.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key
